# Environment variables for AI Automation Pipeline

# Please update this with your actual PostgreSQL database URL
# Example format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_automation"

# Gemini API Key for content filtering & generation
GEMINI_API_KEY="AIza..."

# Redis URL (Bonus) - leave empty if not using
REDIS_URL="redis://localhost:6379"

# Server Port
PORT=3000
