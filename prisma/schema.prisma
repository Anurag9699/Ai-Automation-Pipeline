generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model NewsContent {
  id           String   @id @default(uuid())
  title        String
  headline     String   @default("")
  category     String
  caption      String
  hookSentence String   @default("")
  trivia       String
  score        Int
  signalScores Json     @default("{}")
  signalBadge  String   @default("")
  imageUrl     String   @default("")
  sourceUrl    String   @unique
  createdAt    DateTime @default(now())
}
